  "name": "中国数据安全专利 DOCS 四级路由体系",
  "docs_fields": ["abstract", "claim"],
  "tier_definitions": {
    "S": "直接指向数据安全保护对象或专门隐私增强技术的强召回信号。",
    "W": "指向隐私、合规、完整性、备份审计或可信执行等数据安全支撑机制的弱召回信号。",
    "R": "指向通用密码、认证、网络或应用安全的泛安全信号，仅用于扩大候选召回。",
    "E": "未识别出 S/W/R 路由信号；E 是默认路由，不是最终不相关标签。"
  },

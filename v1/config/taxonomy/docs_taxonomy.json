  "routing_rules": [
    {"id": "DOCS-ROUTE-001", "rule": "S/W/R 取实际命中的最高层级，层级顺序为 S、W、R、E。"},
    {"id": "DOCS-ROUTE-002", "rule": "cooccurrence 词项只有在同句或左右 48 字窗口命中 required_any 上下文时才成立。"},
    {"id": "DOCS-ROUTE-003", "rule": "no_positive_evidence_alone 词项不创建候选，只用于解释默认 E。"},
    {"id": "DOCS-ROUTE-004", "rule": "诊断场景只记录，不能降低、覆盖或排除 S/W/R 命中。"},
